# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Contact Information
VITE_CONTACT_EMAIL="seu@email.com"
VITE_CONTACT_PHONE="seu-telefone"
VITE_CONTACT_WHATSAPP="seu-whatsapp"
VITE_CONTACT_WHATSAPP_LINK="https://wa.me/seu-numero"
VITE_CONTACT_LOCATION="Sua Localização"

# Social Media Links
VITE_SOCIAL_INSTAGRAM="#"
VITE_SOCIAL_LINKEDIN="#"
VITE_SOCIAL_GITHUB="#"
VITE_SOCIAL_TWITTER="#"

# SEO / General
VITE_SITE_URL="https://seu-site.com.br/"
VITE_SITE_NAME="Seu Nome da Empresa"
